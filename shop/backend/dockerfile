FROM golang:1.23-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o sneaker-backend .

FROM alpine:3.19

WORKDIR /app

RUN apk add --no-cache ca-certificates wget && \
    addgroup -g 1001 -S appgroup && \
    adduser -S appuser -G appgroup -u 1001

COPY --from=builder /app/sneaker-backend .

USER appuser

EXPOSE 8080

CMD ["./sneaker-backend"]
